{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1180px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "queen-green", "name": "Hijau Queen", "color": "#0b5d4b" },
        { "slug": "queen-deep", "name": "Hijau Gelap", "color": "#063c31" },
        { "slug": "queen-gold", "name": "Emas", "color": "#d4a72c" },
        { "slug": "queen-cream", "name": "Krem", "color": "#f6f1e6" },
        { "slug": "ink", "name": "Tinta", "color": "#162521" },
        { "slug": "muted", "name": "Abu Hijau", "color": "#61726c" },
        { "slug": "white", "name": "Putih", "color": "#ffffff" }
      ],
      "gradients": [
        {
          "slug": "queen-hero",
          "name": "Queen Hero",
          "gradient": "linear-gradient(135deg, #063c31 0%, #0b5d4b 58%, #147c64 100%)"
        }
      ]
    },
    "spacing": {
      "units": ["px", "rem", "%", "vw"],
      "spacingSizes": [
        { "slug": "20", "name": "XS", "size": "0.5rem" },
        { "slug": "30", "name": "S", "size": "0.875rem" },
        { "slug": "40", "name": "M", "size": "1.5rem" },
        { "slug": "50", "name": "L", "size": "2.5rem" },
        { "slug": "60", "name": "XL", "size": "4rem" }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
          "name": "Queen Sans",
          "slug": "queen-sans"
        },
        {
          "fontFamily": "Georgia, 'Times New Roman', serif",
          "name": "Queen Serif",
          "slug": "queen-serif"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "Kecil" },
        { "slug": "medium", "size": "1rem", "name": "Normal" },
        { "slug": "large", "size": "clamp(1.25rem, 2vw, 1.5rem)", "name": "Besar" },
        { "slug": "x-large", "size": "clamp(1.75rem, 4vw, 3rem)", "name": "Sangat Besar" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#162521"
    },
    "spacing": {
      "blockGap": "1.5rem"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--queen-sans)",
      "fontSize": "1rem",
      "lineHeight": "1.7"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontWeight": "750",
          "lineHeight": "1.18"
        },
        "color": { "text": "#162521" }
      },
      "link": {
        "color": { "text": "#0b5d4b" },
        ":hover": { "color": { "text": "#063c31" } }
      },
      "button": {
        "border": { "radius": "999px" },
        "color": { "background": "#0b5d4b", "text": "#ffffff" },
        "spacing": { "padding": { "top": "0.75rem", "right": "1.25rem", "bottom": "0.75rem", "left": "1.25rem" } },
        "typography": { "fontWeight": "700" }
      }
    },
    "blocks": {
      "core/quote": {
        "border": { "left": { "color": "#d4a72c", "style": "solid", "width": "4px" } },
        "spacing": { "padding": { "left": "1.5rem" } }
      },
      "core/image": { "border": { "radius": "18px" } }
    }
  }
}
